<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.javaminiproject.controller.LoginController"
           styleClass="login-root" prefWidth="900" prefHeight="600">

    <HBox alignment="CENTER">
        <!-- Left panel -->
        <VBox alignment="CENTER" prefWidth="420" prefHeight="600" spacing="12">
            <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

            <ImageView fitWidth="230" fitHeight="230" preserveRatio="true">
                <image>
                    <Image url="@Main.png"/>
                </image>
            </ImageView>

            <Label text="Faculty of Technology"
                   style="-fx-font-size:26;-fx-font-weight:bold;-fx-text-fill:white;"/>

            <Label text="Learning Management System"
                   style="-fx-font-size:14;-fx-text-fill:#8899aa;"/>

            <Label text="Manage courses, marks, attendance&#10;and more — all in one place."
                   style="-fx-text-fill:#aabbcc;-fx-font-size:13;-fx-wrap-text:true;"
                   wrapText="true"/>
        </VBox>

        <!-- Login card -->
        <VBox styleClass="login-card" spacing="14" alignment="CENTER" prefWidth="380">
            <Label text="Sign In" styleClass="login-title"/>
            <Label text="Enter your credentials to continue" styleClass="login-subtitle"/>

            <VBox spacing="4">
                <Label text="USERNAME" styleClass="field-label"/>
                <TextField fx:id="usernameField" promptText="Enter username" styleClass="text-field" prefWidth="280"/>
            </VBox>

            <VBox spacing="4">
                <Label text="PASSWORD" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="password-field" prefWidth="280"/>
            </VBox>

            <Label fx:id="errorLabel" style="-fx-text-fill:#dc3545;-fx-font-size:12;" text="" wrapText="true"/>

            <Button text="LOGIN" styleClass="btn-primary" prefWidth="280"
                    onAction="#handleLogin" defaultButton="true"/>

            <Label text="Default credentials: admin / admin123" style="-fx-text-fill:#8899aa;-fx-font-size:11;"/>
        </VBox>
    </HBox>
</StackPane>